# TypeMeter Security Configuration Example
# Copy this file to .env and fill in the values.

# Flask Application Key (secret, cryptographically random, used to sign session cookies)
# Generate one using: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_this_with_a_secure_random_key_of_at_least_32_chars

# Environment setting (production requires HTTPS/Secure cookies; development allows HTTP)
ENV=development

# Google OAuth 2.0 Credentials
# Register your application in Google Cloud Console and set redirect URL to:
# http://127.0.0.1:8000/auth/google/callback (in local development)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration

# SMTP Email Settings
# Set these parameters to connect to SMTP. If not configured, verification and reset
# links will be printed directly to the server terminal output for local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@typemeter.local
